{
  "name": "win-boost",
  "version": "0.1.0",
  "description": "Windows 笔记本电源策略自动切换工具：空闲降档 + 卡顿升档",
  "main": "src/main.js",
  "bin": {
    "win-boost": "src/main.js"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "node src/main.js",
    "debug": "cross-env WINBOOST_DEBUG=1 node src/main.js",
    "status": "node src/main.js --status",
    "schemes": "node src/main.js --schemes",
    "once": "node src/main.js --once",
    "test": "node --test \"test/**/*.test.js\"",
    "pkg": "pkg . --config pkg.config.cjs",
    "pkg:win": "pkg . --config pkg.config.cjs -t node18-win-x64 -o dist/win-boost.exe",
    "icon": "node scripts/build-icon-b64.js"
  },
  "dependencies": {
    "koffi": "^2.9.0",
    "systray2": "^2.1.4",
    "winston": "^3.13.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "optionalDependencies": {
    "koffi": "^2.9.0"
  },
  "devDependencies": {
    "@yao-pkg/pkg": "^5.12.0",
    "cross-env": "^7.0.3"
  },
  "pkg": {
    "scripts": [
      "src/**/*.js"
    ],
    "assets": [
      "res/tray-icon.b64",
      "node_modules/systray2/traybin/**/*"
    ],
    "targets": [
      "node18-win-x64"
    ],
    "outputPath": "dist",
    "output": "win-boost"
  }
}
